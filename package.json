{
    "name": "auto-blogger",
    "version": "0.1.0",
    "description": "AI-powered blog post generator with web research, content gap analysis, and multi-language support",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "auto-blogger": "dist/cli.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsx src/cli.ts",
        "generate": "tsx src/cli.ts",
        "dry-run": "tsx src/cli.ts --dry-run",
        "prepublishOnly": "npm run build",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "blog",
        "ai",
        "content-generation",
        "openai",
        "seo",
        "markdown",
        "multilingual",
        "newsletter",
        "auto-blogger"
    ],
    "license": "MIT",
    "dependencies": {
        "glob": "^11.0.0",
        "gray-matter": "^4.0.3",
        "openai": "^6.27.0",
        "slugify": "^1.6.6"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0"
    },
    "engines": {
        "node": ">=18"
    }
}
